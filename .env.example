# ---- Supabase ----
# The app auto-detects whether these are real. With placeholders (or unset) it
# runs on the in-memory demo store; fill all three with real values and it uses
# live Postgres — no code change. Before that, run BOTH migrations in the
# Supabase SQL editor: supabase/migrations/0001_init.sql then 0002_tag_events.sql.
#
# Public (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only. NEVER expose this to the browser. Set in Vercel as a plain env var.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Public base URL of the deployed app (used to build embed/iframe snippets & CORS).
# Locally: http://localhost:3000 ; On Vercel: your production domain.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---- Google Calendar (booking calendars) ----
# Like Supabase, this auto-detects: with placeholders (or unset) the booking
# calendars run in DEMO mode — availability ignores Google and events are
# mocked. Fill these with a real OAuth client (Google Cloud Console → APIs &
# Services → Credentials → OAuth client ID, type "Web application") to go live,
# then click "Connect Google account" on Settings → Integrations. The refresh
# token minted there is stored in the DB, NOT here.
#
# Authorized redirect URI to add in the console: <APP_URL>/api/google/callback
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
# Optional — defaults to <NEXT_PUBLIC_APP_URL>/api/google/callback
# GOOGLE_REDIRECT_URI=http://localhost:3000/api/google/callback

# ---- Stripe (accept payment for paid calendars) ----
# Auto-detects too: without a real secret key, paid calendars confirm via an
# internal demo step instead of real Checkout. Add the keys to charge for real.
# The webhook secret comes from `stripe listen` (dev) or the Dashboard webhook
# endpoint you point at <APP_URL>/api/stripe/webhook.
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-signing-secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key

# ---- LeadConnector / GoHighLevel (email automations transport) ----
# Auto-detects like the others: without a real API key, automation email steps
# are logged as demo sends (the sequence still runs end-to-end) so you can build
# and test workflows now. Add the key to send for real.
LEADCONNECTOR_API_KEY=your-leadconnector-api-key
# Your LeadConnector location/sub-account id (sent with sends/contact upserts).
LEADCONNECTOR_LOCATION_ID=your-location-id
# Optional overrides — defaults target the LeadConnector v2 API and work for
# most accounts. Change only if your account/integration differs.
# LEADCONNECTOR_BASE_URL=https://services.leadconnectorhq.com
# LEADCONNECTOR_API_VERSION=2021-07-28
# LEADCONNECTOR_EMAIL_ENDPOINT=/conversations/messages

# ---- Automations runner (wait/timing engine) ----
# The runner advances email sequences past their wait steps. In prod, point a
# scheduler at <APP_URL>/api/automations/tick every minute with this secret in
# the Authorization header (Bearer <secret>) or ?secret=<secret>. In demo mode
# the "Run now" button on the Automations screen calls the same runner.
#
# Example Vercel Cron (vercel.json):
#   { "crons": [{ "path": "/api/automations/tick?secret=YOUR_SECRET", "schedule": "* * * * *" }] }
AUTOMATIONS_CRON_SECRET=change-me-to-a-long-random-string

# ---- Email (deferred / design-forward; leave blank for now) ----
# EMAIL_PROVIDER=noop            # noop | resend | postmark
# EMAIL_API_KEY=
# EMAIL_FROM="Lucy Coaching <hello@example.com>"
